---
import { Icon } from "astro-icon/components";
---

<section
  id="hero"
  class="flex min-h-[85vh] flex-col items-center justify-center px-6 text-center"
>
  <h1
    class="text-text mb-4 text-5xl tracking-tight opacity-0 sm:text-6xl md:mb-6 md:text-7xl"
    data-animate="hero"
  >
    Hi, I'm <span class="text-text-muted">Maya.</span>
  </h1>

  <p
    class="text-text-muted mb-8 max-w-lg text-lg opacity-0 sm:text-xl md:mb-10"
    data-animate="hero"
  >
    Full-stack engineer who likes building systems that <span
      class="text-lavender-600 dark:text-lavender-400">just work</span
    >.
  </p>

  <nav
    class="flex items-center gap-5 opacity-0"
    aria-label="Social links"
    data-animate="hero"
  >
    <a
      href="https://github.com/maya-maddox"
      target="_blank"
      rel="noopener noreferrer"
      class="text-text-muted hover:text-text transition-all duration-300 hover:-translate-y-1"
      aria-label="GitHub"
    >
      <Icon name="lucide:github" class="size-6" />
    </a>
    <a
      href="https://linkedin.com/in/mayamaddox"
      target="_blank"
      rel="noopener noreferrer"
      class="text-text-muted hover:text-text transition-all duration-300 hover:-translate-y-1"
      aria-label="LinkedIn"
    >
      <Icon name="lucide:linkedin" class="size-6" />
    </a>
    <a
      href="mailto:hello@mayamaddox.com"
      class="text-text-muted hover:text-text transition-all duration-300 hover:-translate-y-1"
      aria-label="Email"
    >
      <Icon name="lucide:mail" class="size-6" />
    </a>
  </nav>
</section>

<script>
  import { animate, stagger } from "motion";

  animate(
    "[data-animate='hero']",
    { opacity: [0, 1], y: [20, 0] },
    {
      duration: 0.8,
      delay: stagger(0.25, { startDelay: 0.1 }),
    },
  );
</script>
